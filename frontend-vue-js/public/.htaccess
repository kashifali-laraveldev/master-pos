<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let existing files/directories pass through.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for Vue Router history mode.
  RewriteRule ^ index.html [L]
</IfModule>
